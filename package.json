{
  "name": "tollway",
  "version": "0.0.0",
  "private": true,
  "description": "Open protocol for how AI agents access the web",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TollwayProtocol/Tollway.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "test:coverage": "turbo test -- --coverage",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "schema:validate": "node scripts/validate-schemas.mjs",
    "clean": "turbo clean",
    "format": "prettier --write \"**/*.{ts,js,json,md,yaml}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "turbo": "^2.3.3",
    "typescript": "^5.5.4",
    "yaml": "^2.8.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.8.2"
}
